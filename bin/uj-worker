#!/usr/bin/env python3
"""
UltraJarvis Worker - Process queued natural language tasks
"""
import sys
import os
import logging

project_root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
sys.path.insert(0, project_root)

logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s'
)

if __name__ == "__main__":
    from core.job_worker import run_forever
    run_forever()
